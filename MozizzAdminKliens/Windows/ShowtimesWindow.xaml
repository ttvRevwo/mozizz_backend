<Window x:Class="MozizzAdminKliens.Windows.ShowtimesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vetítések" Height="460" Width="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="dgShowtimes"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding showtimeId}" Width="50"/>
                <DataGridTextColumn Header="Film" Binding="{Binding movieTitle}" Width="200"/>
                <DataGridTextColumn Header="Dátum" Binding="{Binding showDate}" Width="120"/>
                <DataGridTextColumn Header="Időpont" Binding="{Binding showTime}" Width="90"/>
                <DataGridTextColumn Header="Terem" Binding="{Binding hallName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Frissítés" Click="btnRefresh_Click" Padding="8,5" Margin="0,0,8,0"/>
            <Button Content="Kiválasztott törlése" Click="btnDelete_Click" Padding="8,5" Margin="0,0,8,0"/>
            <TextBlock x:Name="tbStatus" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>
