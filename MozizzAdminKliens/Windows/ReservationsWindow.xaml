<Window x:Class="MozizzAdminKliens.Windows.ReservationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foglalások" Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Felhasználó ID:"/>
            <TextBox x:Name="tbxUserId" Width="80" VerticalContentAlignment="Center"/>
            <Button Content="Betöltés" Click="btnLoad_Click" Padding="8,3" Margin="8,0,0,0"/>
            <Button Content="Frissítés" Click="btnRefresh_Click" Padding="8,3" Margin="4,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  x:Name="dgReservations"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding reservationId}" Width="50"/>
                <DataGridTextColumn Header="Film" Binding="{Binding filmCim}" Width="200"/>
                <DataGridTextColumn Header="Dátum" Binding="{Binding datum}" Width="100"/>
                <DataGridTextColumn Header="Időpont" Binding="{Binding idopont}" Width="90"/>
                <DataGridTextColumn Header="Székek" Binding="{Binding szekek}" Width="180"/>
                <DataGridTextColumn Header="Státusz" Binding="{Binding statusz}" Width="100"/>
                <DataGridTextColumn Header="Végösszeg" Binding="{Binding vegosszeg}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Kiválasztott lemondása" Click="btnCancel_Click" Padding="8,5" Margin="0,0,8,0"/>
            <TextBlock x:Name="tbStatus" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>
