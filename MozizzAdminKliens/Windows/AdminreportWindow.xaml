<Window x:Class="MozizzAdminKliens.Windows.AdminReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin riportok" Height="580" Width="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Mai napi riport" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="tbDatum" FontWeight="Bold" Margin="0,0,20,0"/>
                    <TextBlock x:Name="tbBevetel" Margin="0,0,20,0"/>
                    <TextBlock x:Name="tbJegyek" Margin="0,0,20,0"/>
                    <TextBlock x:Name="tbFoglalasok"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Top 3 film (legtöbb jegy)" Margin="0,0,0,10">
            <DataGrid x:Name="dgTopMovies"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Height="120"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Film" Binding="{Binding filmCim}" Width="*"/>
                    <DataGridTextColumn Header="Jegyek" Binding="{Binding jegyekSzama}" Width="80"/>
                    <DataGridTextColumn Header="Bevétel" Binding="{Binding bevetel}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Vetítések telítettsége" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Margin="4">
                <RadioButton x:Name="rbAktiv" Content="Aktív vetítések" IsChecked="True" Margin="0,0,16,0" Checked="rbAktiv_Checked"/>
                <RadioButton x:Name="rbArchiv" Content="Archív vetítések" Checked="rbArchiv_Checked"/>
            </StackPanel>
        </GroupBox>

        <DataGrid Grid.Row="3"
                  x:Name="dgOccupancy"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Film" Binding="{Binding film}" Width="200"/>
                <DataGridTextColumn Header="Időpont" Binding="{Binding idopont}" Width="160"/>
                <DataGridTextColumn Header="Eladott jegyek" Binding="{Binding eladottJegyek}" Width="110"/>
                <DataGridTextColumn Header="Telítettség" Binding="{Binding telitettseg}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
