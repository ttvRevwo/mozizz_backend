<Window x:Class="MozizzAdminKliens.Windows.NewShowtimeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Új vetítés" Height="320" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <StackPanel>
            <Label Content="Film"/>
            <ComboBox x:Name="cmbMovies" DisplayMemberPath="title" SelectedValuePath="movieId"/>
            <Label Content="Terem" Margin="0,8,0,0"/>
            <ComboBox x:Name="cmbHalls" DisplayMemberPath="name" SelectedValuePath="hallId"/>
            <Label Content="Dátum (éééé-hh-nn)" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxDate" Text="2026-04-01"/>
            <Label Content="Időpont (óó:pp)" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxTime" Text="18:00"/>
            <Button Content="Vetítés mentése" Click="btnSave_Click" Padding="5" Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</Window>
