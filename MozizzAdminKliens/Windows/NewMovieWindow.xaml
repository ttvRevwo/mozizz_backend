<Window x:Class="MozizzAdminKliens.Windows.NewMovieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Új film" Height="560" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel>
            <Label Content="Cím"/>
            <TextBox x:Name="tbxTitle"/>
            <Label Content="Műfaj" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxGenre"/>
            <Label Content="Hossz (perc)" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxDuration"/>
            <Label Content="Értékelés (pl. PG-13)" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxRating"/>
            <Label Content="Leírás" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxDescription" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
            <Label Content="Kép URL (img)" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxImg"/>
            <Label Content="Megjelenés dátuma (ÉÉÉÉ-HH-NN)" Margin="0,8,0,0"/>
            <TextBox x:Name="tbxReleaseDate"/>
            <Button Content="Film mentése" Click="btnSave_Click" Padding="5" Margin="0,16,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
