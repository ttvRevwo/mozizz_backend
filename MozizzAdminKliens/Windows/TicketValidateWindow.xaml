<Window x:Class="MozizzAdminKliens.Windows.TicketValidateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jegy validálás" Height="320" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="16">
        <StackPanel>
            <Label Content="Jegy kód beírása:" FontSize="14"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBox x:Name="tbxTicketCode" Width="260" FontSize="14" VerticalContentAlignment="Center"/>
                <Button Content="Validálás" Click="btnValidate_Click" Padding="10,5" Margin="8,0,0,0" FontSize="14"/>
            </StackPanel>

            <Border x:Name="borderResult"
                    Margin="0,20,0,0"
                    Padding="12"
                    CornerRadius="6"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="tbResultTitle" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBlock x:Name="tbResultDetails" TextWrapping="Wrap" FontSize="13"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
