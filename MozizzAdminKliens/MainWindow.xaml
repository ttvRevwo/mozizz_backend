<Window x:Class="MozizzAdminKliens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mozizz Admin" Height="600" Width="1000">
    <Window.Resources>
        <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Menu Height="35" VerticalAlignment="Top" Padding="3">
            <MenuItem Header="Login" Name="itemLogin" Click="MenuLogin_Click"/>
            <MenuItem Header="Felhasználók" Name="itemUsers" IsEnabled="False">
                <MenuItem Header="Felhasználók listája" Click="itemUserList_Click"/>
            </MenuItem>
            <MenuItem Header="Jegyek" Name="itemTickets" IsEnabled="False">
                <MenuItem Header="Jegy validálás" Click="itemTicketValidate_Click"/>
                <MenuItem Header="Jegyek listája" Click="itemTicketList_Click"/>
            </MenuItem>
            <MenuItem Header="Filmek" Name="itemMovies" IsEnabled="False">
                <MenuItem Header="Filmek listája" Click="itemMovieList_Click"/>
                <MenuItem Header="Új film" Click="itemNewMovie_Click"/>
            </MenuItem>

        </Menu>
        <TextBlock Name="tbWelcome"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   FontSize="22"
                   Foreground="Gray"
                   Text="Kérjük, jelentkezz be az adminisztrációs felülethez."/>
    </Grid>
</Window>
